{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@multi-ai/shared": ["packages/shared/src/index.ts"],
      "@multi-ai/shared/*": ["packages/shared/src/*"],
      "@multi-ai/db": ["packages/db/src/index.ts"],
      "@multi-ai/db/*": ["packages/db/src/*"],
      "@multi-ai/browser-runner": ["packages/browser-runner/src/index.ts"],
      "@multi-ai/browser-runner/*": ["packages/browser-runner/src/*"],
      "@multi-ai/providers": ["packages/providers/src/index.ts"],
      "@multi-ai/providers/*": ["packages/providers/src/*"],
      "@multi-ai/orchestrator": ["packages/orchestrator/src/index.ts"],
      "@multi-ai/orchestrator/*": ["packages/orchestrator/src/*"],
      "@multi-ai/synthesizer": ["packages/synthesizer/src/index.ts"],
      "@multi-ai/synthesizer/*": ["packages/synthesizer/src/*"],
      "@multi-ai/export": ["packages/export/src/index.ts"],
      "@multi-ai/export/*": ["packages/export/src/*"],
      "@multi-ai/logger": ["packages/logger/src/index.ts"],
      "@multi-ai/logger/*": ["packages/logger/src/*"]
    }
  }
}
